# Confluence Downloader - Environment Variables

# Base URL of your Confluence instance
# Cloud: https://your-domain.atlassian.net
# Server/Data Center: https://confluence.your-company.com
CONFLUENCE_URL=

# API Token (Cloud) or Personal Access Token (Server/Data Center)
CONFLUENCE_API_TOKEN=

# Email address associated with the API Token (Cloud only, not required for Server/DC)
CONFLUENCE_EMAIL=
